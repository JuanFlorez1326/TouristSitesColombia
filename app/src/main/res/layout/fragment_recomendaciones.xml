<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#EAEAEA">

    <ScrollView
        android:id="@+id/llContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recomendaciones"
                android:textColor="#333333"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Recomendaciones para tu viaje a Tolú"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#555555"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="32dp"
                android:text="1. Clima y qué llevar\n• Hace bastante calor (entre 28°C y 34°C).\n• Lleva ropa ligera, bloqueador solar, gafas de sol y gorra.\n• No olvides repelente (hay mosquitos, sobre todo en la tarde).\n\n2. Playas y actividades\n• Disfruta las playas tranquilas de Tolú, ideales para descansar.\n• Visita las Islas de San Bernardo (plan imperdible).\n• Puedes hacer: Paseos en lancha, Snorkel, Avistamiento de fauna marina.\n\n3. Dinero y pagos\n• Lleva efectivo (no todos los sitios aceptan tarjeta).\n• Pregunta precios antes de contratar tours." />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Utilidades y Enlaces"
                android:textColor="#333333"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/etBuscadorUrl"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_search_bar"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="12dp"
                android:hint="Escribe una URL para buscar..."
                android:imeOptions="actionGo"
                android:inputType="textUri"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#333333"
                android:textColorHint="#999999"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enlaces útiles para tu viaje"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Información general del destino"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvLink1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="colombiaturismo.com.co/tolu.html"
                android:textColor="#0066CC"
                android:paddingTop="4dp"
                android:paddingBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Actividades y qué hacer"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvLink2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="https://pajoytours.com/tolu/"
                android:textColor="#0066CC"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"/>

            <TextView
                android:id="@+id/tvLink3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="https://www.colombia.com/turismo/sitios-turisticos/tolu/"
                android:textColor="#0066CC"
                android:paddingTop="4dp"
                android:paddingBottom="32dp"/>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/llWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#EAF3F8"
            android:elevation="4dp"
            android:paddingHorizontal="8dp">

            <ImageButton
                android:id="@+id/btnCerrarWeb"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#333333"/>

            <TextView
                android:id="@+id/tvWebTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Navegador"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </LinearLayout>

</FrameLayout>