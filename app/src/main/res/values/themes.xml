<resources>

    <style name="Base.Theme.TouristSitesColombia" parent="Theme.Material3.DayNight.NoActionBar">

    </style>

    <style name="Theme.TouristSitesColombia" parent="Base.Theme.TouristSitesColombia" />

    <style name="SidebarItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_marginHorizontal">8dp</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingHorizontal">14dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <style name="SidebarIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
    </style>

    <style name="SidebarText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:singleLine">true</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:alpha">0</item>
    </style>
</resources>